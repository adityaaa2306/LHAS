###############################################################################
# LHAS Docker Compose Environment Configuration Template
# 
# Copy this file to .env and update with your values:
#   cp .env.example .env
#
# This file is loaded by docker-compose.yml for all services
# All variables are optional and have sensible defaults
###############################################################################

#==============================================================================
# PostgreSQL Configuration
#==============================================================================

# Database credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=aditya
POSTGRES_DB=LHAS
POSTGRES_PORT=5432

#==============================================================================
# Backend API Configuration
#==============================================================================

# Application environment: development, staging, production
ENVIRONMENT=production

# Debug mode (only use in development)
DEBUG=false

# Log SQL queries (useful for optimization, disable in production)
SQL_ECHO=false

# Backend API port
BACKEND_PORT=8000

# Database connection pool size
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

#==============================================================================
# Frontend Configuration
#==============================================================================

# Frontend port
FRONTEND_PORT=3000

# Node environment
NODE_ENV=production

#==============================================================================
# API Keys & External Services
#==============================================================================

# NVIDIA NIM Configuration (LLM Provider)
# Get API Key from: https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_TEMPERATURE=0.6
NVIDIA_TOP_P=0.7
NVIDIA_MAX_TOKENS=4096

# OpenAI API Key for synthesis generation
# Get from: https://platform.openai.com/api-keys
# Optional - only needed if implementing synthesis features
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (if using Claude models)
# Get from: https://console.anthropic.com/
# Optional
ANTHROPIC_API_KEY=your_anthropic_api_key_here

#==============================================================================
# Logging Configuration
#==============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json (for ELK/Datadog) or text (human readable)
LOG_FORMAT=text

#==============================================================================
# Security & CORS
#==============================================================================

# CORS origins (comma-separated list)
# Examples: http://localhost:3000,https://yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://frontend:3000

#==============================================================================
# Optional: Nginx Reverse Proxy Configuration
#==============================================================================

# Uncomment these for production with Nginx reverse proxy
# NGINX_VERSION=alpine
# NGINX_PORT=80
# NGINX_SSL_PORT=443

#==============================================================================
# Optional: Monitoring & Observability
#==============================================================================

# Sentry DSN for error tracking and performance monitoring
# Get from: https://sentry.io/
# Optional - leave empty to disable
SENTRY_DSN=

# Datadog API Key for metrics and logs
# Get from: https://datadog.com/
# Optional - leave empty to disable
DATADOG_API_KEY=

# OpenTelemetry collector endpoint (for distributed tracing)
# Example: http://otel-collector:4317
# Optional
OTEL_COLLECTOR_ENDPOINT=

#==============================================================================
# Optional: Caching (for future use)
#==============================================================================

# Redis URL for caching
# Example: redis://redis:6379/0
# Optional - leave empty to disable
REDIS_URL=

#==============================================================================
# Optional: Message Queue (for future use)
#==============================================================================

# RabbitMQ URL for task queue
# Example: amqp://guest:guest@rabbitmq:5672//
# Optional - leave empty to disable
RABBITMQ_URL=

#==============================================================================
# File Storage Configuration (for future use)
#==============================================================================

# S3 bucket for PDF storage
# Optional - leave empty to use local storage
S3_BUCKET=

# S3 region
S3_REGION=us-east-1

# S3 access key (use IAM role in AWS for production)
S3_ACCESS_KEY=

# S3 secret key
S3_SECRET_KEY=

#==============================================================================
# Development/Local Database (when not using Docker)
#==============================================================================

# Local development database URL (overrides POSTGRES_* variables)
# Only used when running services outside Docker
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/lhas

#==============================================================================
# Notes
#==============================================================================

# Production Security Checklist:
#   ✓ Use strong credentials (not postgres:postgres)
#   ✓ Set ENVIRONMENT=production
#   ✓ Set DEBUG=false
#   ✓ Use managed database (AWS RDS, Google Cloud SQL)
#   ✓ Configure proper CORS_ORIGINS
#   ✓ Enable SSL/TLS for all endpoints
#   ✓ Store secrets in secure vault (not .env file)
#   ✓ Configure backups and disaster recovery
#   ✓ Setup monitoring and alerting
#   ✓ Use VPN/firewall rules for database access

# Performance Tuning:
#   • DB_POOL_SIZE: 20 for dev, 50-100 for production
#   • Use CDN for frontend static assets in production
#   • Enable query caching with Redis for frequently accessed data
#   • Consider Kubernetes for scaling beyond single machine

# For more information, see:
#   - docker-compose.yml (service configuration)
#   - README.md (setup & deployment guide)
#   - backend/README.md (backend-specific configuration)
#   - frontend/.env (frontend environment variables)
