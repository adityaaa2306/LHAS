#==============================================================================
# Environment & Configuration (SENSITIVE - NEVER COMMIT REAL VALUES)
#==============================================================================

# Actual environment files with real credentials/API keys (DO NOT COMMIT)
.env
.env.local
.env.*.local
.env.production
.env.production.local
.env.development.local
backend/.env
backend/.env.local
backend/.env.production
frontend/.env
frontend/.env.local

# Note: .env.example SHOULD be committed (it's a template with placeholders)

#==============================================================================
# Frontend Node.js
#==============================================================================

frontend/node_modules/
frontend/.pnp
frontend/.pnp.js
frontend/dist/
frontend/dist-ssr/
frontend/coverage/
frontend/.nyc_output/

# Frontend Logs
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*
frontend/lerna-debug.log*

# Frontend Local Environment
frontend/.env
frontend/.env.local
frontend/.env.*.local

