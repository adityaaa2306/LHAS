*.tmp
*.temp
*.bak
*.backup
*.swp
*.swo
*~
.#*

#==============================================================================
# Database Files (should be in Docker volumes)
#==============================================================================

*.db
*.sqlite
*.sqlite3
*.dbf

#==============================================================================
# Credentials, Keys & Secrets (CRITICAL - NEVER COMMIT)
#==============================================================================

# Private key files
*.pem
*.key
*.key.pem
*.crt
*.cert
*.p12
*.pfx
.keystore

# Credential storage directories
.aws/
.credentials
.ssh/
secrets/
.vault/
creds/

# API Key backup files
*.apikey
*.secret
*.token

# Certificate directories
certs/
keys/
!certs/.gitkeep
!keys/.gitkeep

#==============================================================================
# Large Model & Binary Files
#==============================================================================

backend/*.bin
backend/*.pt
backend/*.safetensors
backend/embeddings_cache/
*.model
*.pickle
*.pkl
*.joblib

#==============================================================================
# Database Backups
#==============================================================================

*.sql
*.sql.backup
*.sql.dump
*.pg_dump
postgres_data/
db_backups/

#==============================================================================
# Keep directories with .gitkeep
#==============================================================================

!**/.gitkeep
